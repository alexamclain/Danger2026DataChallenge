p = 100000000000000000000117 (77 bits), k = 39 doublings
import Mathlib.Tactic.NormNum

def mongDbl (p C X Z : ℤ) : ℤ × ℤ :=
  let U := (X + Z) ^ 2 % p
  let V := (X - Z) ^ 2 % p
  let W := U - V
  (U * V % p, W * (V + C * W) % p)

def mongIter (p C : ℤ) : ℕ → ℤ → ℤ → ℤ × ℤ × ℤ
  | 0, X, Z => (X, Z, 0)
  | n + 1, X₀, Z₀ =>
    let prev := mongIter p C n X₀ Z₀
    let next := mongDbl p C prev.1 prev.2.1
    (next.1, next.2, prev.2.1)

theorem mongIter_step (p C : ℤ) (n : ℕ) (X₀ Z₀ Xn Zn Xn1 Zn1 Zp : ℤ)
    (hprev : mongIter p C n X₀ Z₀ = (Xn, Zn, Zp))
    (hdbl : mongDbl p C Xn Zn = (Xn1, Zn1)) :
    mongIter p C (n + 1) X₀ Z₀ = (Xn1, Zn1, Zn) := by
  show (let prev := mongIter p C n X₀ Z₀
        let next := mongDbl p C prev.1 prev.2.1
        (next.1, next.2, prev.2.1)) = _
  rw [hprev]; dsimp only []; rw [hdbl]

structure PomeranceCert where
  p : ℤ
  A : ℤ
  x₀ : ℤ
  C : ℤ
  k : ℕ
  q : ℕ
  s : ℕ
  bez_disc : ℤ × ℤ
  bez_zprev : ℤ × ℤ

def PomeranceCert.Valid (d : PomeranceCert) : Prop :=
  5 ≤ d.p ∧
  d.p % 2 = 1 ∧
  d.bez_disc.1 * (d.A ^ 2 - 4) + d.bez_disc.2 * d.p = 1 ∧
  4 * d.C % d.p = (d.A + 2) % d.p ∧
  (d.q : ℤ) ^ 2 ≤ d.p ∧
  d.p < ((d.q : ℤ) + 1) ^ 2 ∧
  d.s ^ 2 ≤ 4 * d.q ∧
  4 * d.q < (d.s + 1) ^ 2 ∧
  d.q + 1 + d.s < 2 ^ d.k ∧
  let (_, Z, Zprev) := mongIter d.p d.C d.k (d.x₀ % d.p) 1
  Z % d.p = 0 ∧
  d.bez_zprev.1 * Zprev + d.bez_zprev.2 * d.p = 1

def IsPomeranceTriple (p A x₀ : ℤ) : Prop :=
  ∃ d : PomeranceCert, d.p = p ∧ d.A = A ∧ d.x₀ = x₀ ∧ d.Valid

